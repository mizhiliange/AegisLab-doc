# AegisLab API Configuration
# The base URL for the AegisLab API server
AEGISLAB_API_URL=http://10.10.10.220:32080

# TrainTicket Gateway Configuration
# The URL for the TrainTicket microservices gateway
TRAINTICKET_GATEWAY_URL=http://10.10.10.220:30080

# JuiceFS Configuration
# Redis URL for JuiceFS distributed filesystem
JUICEFS_REDIS_URL=redis://10.10.10.119:6379/1

# Environment Configuration
# Options: dev, test, prod
ENV_MODE=prod

# Optional: Custom mount point for JuiceFS
# Default: /mnt/jfs
# JUICEFS_MOUNT_POINT=/mnt/jfs

# Optional: Data directory path
# Default: ./data
# DATA_DIR=./data
