# AegisLab Environment Configuration
# This file contains environment-specific settings
# Copy this file to .env and fill in your actual values

# Kubernetes Contexts

# Context for development environment
DEV_CONTEXT=your-dev-context

# Context for staging environment
STAGE_CONTEXT=your-stage-context

# Context for production environment
PROD_CONTEXT=your-prod-context

# Context for test environment (e.g., minikube, kind)
TEST_CONTEXT=your-test-context

# AegisLab API Configuration
# The base URL for the AegisLab API server
RCABENCH_BASE_URL=your-api-url

# Admin username for RCABench
RCABENCH_USERNAME=your-username

# Admin password for RCABench
RCABENCH_PASSWORD=your-password

# TrainTicket Gateway Configuration
# The URL for the TrainTicket microservices gateway
TRAINTICKET_GATEWAY_URL=your-trainticket-gateway-url

# JuiceFS Configuration
# Redis URL for JuiceFS distributed filesystem
JUICEFS_REDIS_URL=redis://your-redis-ip:6379/1
